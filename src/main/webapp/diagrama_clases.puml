@startuml
' --- CONFIGURACIÓN VISUAL ---
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor White
    ArrowColor #155DFC
    BorderColor #2B7FFF
}

' --- PAQUETE BEANS (MODELOS) ---
package "es.componentesrey.beans (DTO)" {
    
    class Categoria {
        - idCategoria : byte
        - nombre : String
        - imagen : String
    }

    class Producto {
        - idProducto : short
        - nombre : String
        - descripcion : String
        - precio : double
        - marca : String
        - imagen : String
    }

    class Usuario {
        - idUsuario : short
        - email : String
        - password : String
        - nombre : String
        - apellidos : String
        - nif : String
        - telefono : String
        - direccion : String
        - codigoPostal : String
        - localidad : String
        - provincia : String
        - ultimoAcceso : Date
        - avatar : String
    }

    class LineaCarrito {
        - cantidad : int
        + getImporteTotal() : double
    }

    class LineaPedido {
        - idLinea : short
        - idPedido : short
        - idProducto : short
        - cantidad : short
    }

    class Pedido {
        - idPedido : short
        - fecha : Date
        - estado : String
        - idUsuario : short
        - importe : double
        - iva : double
    }

    ' Relaciones entre Beans
    Producto "1" *-- "1" Categoria : pertenece a >
    LineaCarrito "1" o-- "1" Producto : contiene >
    LineaPedido "1" o-- "1" Producto : contiene >
    Pedido "1" *-- "*" LineaPedido : compuesto por >
}

' --- PAQUETE DAO (ACCESO A DATOS) ---
package "es.componentesrey.DAO" {
    
    class ConnectionFactory {
        {static} ~ ds : DataSource
        {static} ~ conexion : Connection
        {static} ~ DATASOURCE_NAME : String
        {static} + getConnection() : Connection
        {static} + closeConnection() : void
    }

    interface ICategoriaDAO <<interface>> {
        + getCategorias() : List<Categoria>
        + closeConnection() : void
    }

    class CategoriaDAO implements ICategoriaDAO

    interface IProductoDAO <<interface>> {
        + getProductos() : List<Producto>
        + getProductosBusqueda(busqueda : String) : List<Producto>
        + getProductoPorId(idProducto : int) : Producto
        + getMarcas() : List<String>
        + getPrecioMax() : double
        + getPrecioMin() : double
        + closeConnection() : void
    }

    class ProductoDAO implements IProductoDAO

    interface IUsuarioDAO <<interface>> {
        + registrarUsuario(usuario : Usuario) : boolean
        + comprobarEmail(email : String) : boolean
        + getUsuarioPorEmail(correo : String) : Usuario
        + actualizarAvatarUsuario(id : short, avatar : String) : boolean
        + hacerLogin(email : String, pass : String) : Usuario
        + actualizarUltimoAcceso(idUsuario : short) : void
        + actualizarDatosPersonales(usuario : Usuario) : boolean
        + cambiarPassword(idUsuario : short, pass : String) : boolean
        + closeConnection() : void
    }

    class UsuarioDAO implements IUsuarioDAO

    interface IPedidoDAO <<interface>> {
        + guardarCarritoBD(usuario : Usuario, carrito : List<LineaCarrito>, importe : double, iva : double) : void
        + getCarritoBD(idUsuario : short) : List<LineaCarrito>
        + tramitarPedido(usuario : Usuario, carrito : List<LineaCarrito>, importe : double, iva : double) : boolean
        + getPedidosPorUsuario(idUsuario : short) : List<Pedido>
        + closeConnection() : void
    }

    class PedidoDAO implements IPedidoDAO {
        - getLineasDeUnPedido(idPedido : short, conexion : Connection) : List<LineaPedido>
    }

    ' Dependencias de Factory
    CategoriaDAO ..> ConnectionFactory : usa
    ProductoDAO ..> ConnectionFactory : usa
    UsuarioDAO ..> ConnectionFactory : usa
    PedidoDAO ..> ConnectionFactory : usa
}

' --- PAQUETE UTILIDADES ---
package "es.componentesrey.utils" {
    class Utilidades {
        {static} + cifrarMD5(input : String) : String
        {static} - getMd5(input : String) : String
        {static} + calcularLetraDNI(dni : String) : char
        {static} + guardarCarritoEnCookie(response : HttpServletResponse, carrito : List<LineaCarrito>) : void
        {static} + leerCarritoDeCookie(request : HttpServletRequest) : List<LineaCarrito>
        {static} + borrarCookieCarrito(response : HttpServletResponse) : void
    }
}

' --- PAQUETE CONTROLADORES ---
package "es.componentesrey.controllers (Servlets)" {
    class InicioController <<Servlet>>
    class LoginController <<Servlet>>
    class LogoutController <<Servlet>>
    class RegistroController <<Servlet>>
    class RegistroAjaxController <<Servlet>>
    class PerfilController <<Servlet>>
    class CarritoController <<Servlet>>
    class CarritoAjaxController <<Servlet>>
    class ProcesarPedidoController <<Servlet>>
}

' Dependencias Lógicas (Controladores usan DAOs)
InicioController ..> IProductoDAO
InicioController ..> ICategoriaDAO
LoginController ..> IUsuarioDAO
RegistroController ..> IUsuarioDAO
CarritoController ..> IProductoDAO
ProcesarPedidoController ..> IPedidoDAO

@enduml