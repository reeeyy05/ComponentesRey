@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle

' --- COLORES PARA IDENTIFICAR PATRONES ---
skinparam class {
    BackgroundColor<<DTO>> #FFF3CD
    BackgroundColor<<DAO>> #D4EDDA
    BackgroundColor<<Controller>> #CCE5FF
    BackgroundColor<<Utils>> #F8D7DA
    BorderColor #333333
}

package "es.componentesrey.beans" {
    class Categoria <<DTO>> {
        - idCategoria : byte
        - nombre : String
        - imagen : String
    }
    class Producto <<DTO>> {
        - idProducto : short
        - nombre : String
        - descripcion : String
        - precio : double
        - marca : String
        - imagen : String
    }
    class Usuario <<DTO>> {
        - idUsuario : short
        - email : String
        - password : String
        - nombre : String
        - apellidos : String
        - nif : String
        - telefono : String
        - direccion : String
        - codigoPostal : String
        - localidad : String
        - provincia : String
        - ultimoAcceso : Date
        - avatar : String
    }
    class LineaCarrito <<DTO>> {
        - producto : Producto
        - cantidad : short
    }
    class LineaPedido <<DTO>> {
        - idLinea : short
        - idPedido : short
        - producto : Producto
        - cantidad : short
    }
    class Pedido <<DTO>> {
        - idPedido : short
        - fecha : Date
        - estado : String
        - idUsuario : short
        - importe : double
        - iva : double
        - lineas : List<LineaPedido>
    }

    Producto "1" -- "1" Categoria
    LineaCarrito "1" o-- "1" Producto
    LineaPedido "1" o-- "1" Producto
    Pedido "1" *-- "*" LineaPedido
}

package "es.componentesrey.DAO" {
    class ConnectionFactory <<DAO>> {
        {static} ~ ds : DataSource
        {static} + getConnection() : Connection
        {static} + closeConnection() : void
    }
    
    interface ICategoriaDAO <<DAO>>
    interface IProductoDAO <<DAO>>
    interface IUsuarioDAO <<DAO>>
    interface IPedidoDAO <<DAO>>

    class CategoriaDAO <<DAO>> implements ICategoriaDAO
    class ProductoDAO <<DAO>> implements IProductoDAO
    class UsuarioDAO <<DAO>> implements IUsuarioDAO
    class PedidoDAO <<DAO>> implements IPedidoDAO

    CategoriaDAO ..> ConnectionFactory
    ProductoDAO ..> ConnectionFactory
    UsuarioDAO ..> ConnectionFactory
    PedidoDAO ..> ConnectionFactory
}

package "es.componentesrey.utils" {
    class Utilidades <<Utils>> {
        {static} + cifrarMD5(input: String) : String
        {static} + calcularLetraDNI(dni: String) : char
        {static} + guardarCarritoEnCookie(...) : void
        {static} + leerCarritoDeCookie(...) : List<LineaCarrito>
        {static} + borrarCookieCarrito(...) : void
    }
}

package "es.componentesrey.controllers" {
    class InicioController <<Controller>>
    class LoginController <<Controller>>
    class LogoutController <<Controller>>
    class RegistroController <<Controller>>
    class RegistroAjaxController <<Controller>>
    class PerfilController <<Controller>>
    class CarritoController <<Controller>>
    class CarritoAjaxController <<Controller>>
    class ProcesarPedidoController <<Controller>>

    InicioController ..> IProductoDAO
    InicioController ..> ICategoriaDAO
    LoginController ..> IUsuarioDAO
    RegistroController ..> IUsuarioDAO
    RegistroAjaxController ..> IUsuarioDAO
    PerfilController ..> IUsuarioDAO
    PerfilController ..> IPedidoDAO
    CarritoController ..> IProductoDAO
    CarritoController ..> IPedidoDAO
    ProcesarPedidoController ..> IPedidoDAO
}
@enduml